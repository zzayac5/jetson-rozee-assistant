<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
body {
  background: black;
  color: white;
  font-family: sans-serif;
  padding: 20px;
}

h2 {
  margin-top: 0;
}

#history {
  white-space: pre-wrap;
  font-size: 22px;
  min-height: 250px;
  margin-bottom: 20px;
}

.input-row {
  display: flex;
  gap: 10px;
  align-items: center;
}

input {
  font-size: 22px;
  width: 80%;
  padding: 10px;
}

button {
  font-size: 22px;
  padding: 10px 16px;
  cursor: pointer;
}

button:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

#thinking {
  margin-top: 16px;
  font-size: 20px;
  display: none;
}

.dots::after {
  content: "";
  animation: dots 1.2s steps(4, end) infinite;
}

@keyframes dots {
  0%   { content: ""; }
  25%  { content: "."; }
  50%  { content: ".."; }
  75%  { content: "..."; }
  100% { content: ""; }
}
</style>
</head>
<body>

<h2>Nora's AI</h2>

<div id="history">Ready!</div>

<div class="input-row">
  <input id="prompt" placeholder="Type here..." />
  <button id="sendBtn" onclick="send()">Send</button>
</div>

<div id="thinking">I'm thinking<span class="dots"></span></div>

<script>
let isWaiting = false;
let conversation = [];
let currentAssistantText = "";

function renderHistory() {
  const history = document.getElementById("history");
  let text = "";

  for (const msg of conversation) {
    if (msg.role === "user") {
      text += "You: " + msg.content + "\n\n";
    } else if (msg.role === "assistant") {
      text += "AI: " + msg.content + "\n\n";
    }
  }

  history.innerText = text.trim() || "Ready!";
  history.scrollTop = history.scrollHeight;
}

async function send() {
  if (isWaiting) return;

  const promptInput = document.getElementById("prompt");
  const sendBtn = document.getElementById("sendBtn");
  const thinking = document.getElementById("thinking");

  const prompt = promptInput.value.trim();
  if (!prompt) return;

  isWaiting = true;
  sendBtn.disabled = true;
  promptInput.disabled = true;
  thinking.style.display = "block";

  promptInput.value = "";

  conversation.push({ role: "user", content: prompt });
  conversation.push({ role: "assistant", content: "" });
  currentAssistantText = "";

  renderHistory();

  try {
    const response = await fetch("/chat", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ messages: conversation.filter(m => m.content !== "") })
    });

    const reader = response.body.getReader();
    const decoder = new TextDecoder("utf-8");
    let buffer = "";

    while (true) {
      const { value, done } = await reader.read();
      if (done) break;

      buffer += decoder.decode(value, { stream: true });
      const parts = buffer.split("\n\n");
      buffer = parts.pop();

      for (const part of parts) {
        if (!part.startsWith("data: ")) continue;

        const payload = JSON.parse(part.slice(6));

        if (payload.token) {
          currentAssistantText += payload.token;
          conversation[conversation.length - 1].content = currentAssistantText;
          renderHistory();
        }

        if (payload.error) {
          conversation[conversation.length - 1].content = "ERROR: " + payload.error;
          renderHistory();
        }

        if (payload.done) {
          thinking.style.display = "none";
          sendBtn.disabled = false;
          promptInput.disabled = false;
          promptInput.focus();
          isWaiting = false;
        }
      }
    }
  } catch (err) {
    conversation[conversation.length - 1].content = "ERROR: " + err.message;
    renderHistory();
    thinking.style.display = "none";
    sendBtn.disabled = false;
    promptInput.disabled = false;
    promptInput.focus();
    isWaiting = false;
  }
}

document.getElementById("prompt").addEventListener("keydown", function(event) {
  if (event.key === "Enter" && !isWaiting) {
    send();
  }
});
</script>

</body>
</html>
